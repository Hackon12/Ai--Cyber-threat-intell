# Copy this to .env and fill in your API keys for external services.
# Do NOT commit your real keys to version control.

# API key for AbuseIPDB (optional)
ABUSEIPDB_API_KEY=

# API key for VirusTotal (optional)
VIRUSTOTAL_API_KEY=

# API key for AlienVault OTX (optional)
OTX_API_KEY=

# Frontend development: override WS URL if backend runs on a different host/port
# For example: ws://127.0.0.1:8000/ws/traffic
REACT_APP_WS_URL=
